# Static analysis for the C sources. Advisory by default (no WarningsAsErrors).
# Run e.g.:  clang-tidy components/core/src/pid.c -- -Icomponents/core/include
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-braces-around-statements

WarningsAsErrors: ''
HeaderFilterRegex: 'components/(core|hal|drivers)/.*'
FormatStyle: file
