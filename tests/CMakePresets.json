{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "host",
      "displayName": "Host unit tests (Debug)",
      "description": "Native Windows/Linux build of the portable core + unit tests.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/host",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "host-release",
      "inherits": "host",
      "displayName": "Host unit tests (Release)",
      "binaryDir": "${sourceDir}/../build/host-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "host", "configurePreset": "host" },
    { "name": "host-release", "configurePreset": "host-release" }
  ],
  "testPresets": [
    {
      "name": "host",
      "configurePreset": "host",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "host-release",
      "configurePreset": "host-release",
      "output": { "outputOnFailure": true }
    }
  ]
}
